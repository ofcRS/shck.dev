---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { TOOLS } from '../site.config';

// One release collection per tool (see content.config.ts) — fetched from
// github.com/<repo>/releases.atom at build time; a repository_dispatch from each
// tool repo rebuilds this page on every release. Nothing here is hand-maintained.
const sections = await Promise.all(
  TOOLS.map(async (t) => {
    let entries: any[] = [];
    try {
      entries = (await getCollection(`releases_${t.name}` as any)) as any[];
    } catch {
      entries = [];
    }
    const releases = entries
      .map((e) => {
        const d: any = e.data;
        return {
          title: d.title ?? e.id,
          url: d.url ?? `https://github.com/${t.repo}/releases`,
          // feed-loader v2 schema: releases.atom date lives in `updated` (published is
          // null for GitHub releases), the release body in `content`.
          date: d.updated ?? d.published ?? null,
          html: d.content ?? d.description ?? '',
        };
      })
      .sort((a, b) => new Date(b.date ?? 0).valueOf() - new Date(a.date ?? 0).valueOf());
    return { tool: t, releases };
  }),
);

const version = (title: string) => {
  const m = title.match(/v?(\d+\.\d+\.\d+)/);
  return m ? `v${m[1]}` : '—';
};

const latest = sections
  .map(({ tool, releases }) => (releases[0] ? { tool, release: releases[0] } : null))
  .filter(
    (x): x is { tool: (typeof TOOLS)[number]; release: (typeof sections)[number]['releases'][number] } =>
      x !== null,
  )
  .sort((a, b) => new Date(b.release.date ?? 0).valueOf() - new Date(a.release.date ?? 0).valueOf())
  .map(({ tool, release }) => ({ label: `${tool.name} ${version(release.title)}` }))[0];

const iso = (d: string | Date | null | undefined) =>
  d ? new Date(d).toISOString().slice(0, 10) : '';
---

<Base title="changelog" description="Release notes for ccx and notion-mcp.">
  <section class="rise">
    <h1>changelog</h1>
    {latest && <div class="stamp">latest: {latest.label}</div>}
  </section>

  {
    sections.map(({ tool, releases }) => (
      <section class="rise toolsec">
        <div class="toolhead">
          <span class="tname">
            <a href={`https://github.com/${tool.repo}`}>{tool.name}</a>
          </span>
          <span class="trepo">{tool.repo}</span>
        </div>
        <p class="note">{tool.blurb}</p>
        {releases.length ? (
          <div class="rels">
            {releases.map((r, i) => (
              <div class="rel">
                <div class="relhead">
                  <a class="title" href={r.url}>
                    {r.title}
                  </a>
                  <span class="rmeta">
                    {i === 0 && <span class="cur">current</span>}
                    <span class="date">{iso(r.date)}</span>
                  </span>
                </div>
                {r.html && <div class="relbody" set:html={r.html} />}
              </div>
            ))}
          </div>
        ) : (
          <p class="note">(no releases yet)</p>
        )}
      </section>
    ))
  }
</Base>

<style>
  .toolsec { margin-top: 40px; }
  .toolhead { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; padding-bottom: 8px; border-bottom: 2px solid var(--rule); }
  .tname { font-size: 19px; font-weight: 600; }
  .tname a { color: var(--ink); text-decoration: none; }
  .tname a:hover { box-shadow: inset 0 -0.5em 0 var(--signal); }
  .trepo { font-family: var(--pixel); font-size: 10px; letter-spacing: 0.4px; text-transform: uppercase; color: var(--gray); }
  .toolsec .note { margin: 10px 0 14px; }

  .rels { border-top: 1px solid var(--rule); border-left: 1px solid var(--rule); border-right: 1px solid var(--rule); }
  .rel { padding: 14px 22px; border-bottom: 1px solid var(--rule); }
  .relhead { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
  .relhead .title { font-size: 15px; font-weight: 600; color: var(--ink); text-decoration: none; }
  .relhead .title:hover { box-shadow: inset 0 -0.5em 0 var(--signal); }
  .rmeta { display: flex; align-items: center; gap: 9px; white-space: nowrap; }
  .cur { font-family: var(--pixel); font-size: 9px; letter-spacing: 0.4px; text-transform: uppercase; background: var(--signal); color: var(--ink); padding: 3px 5px 2px; }
  .date { font-family: var(--pixel); font-size: 10px; letter-spacing: 0.4px; text-transform: uppercase; color: var(--gray); }

  .relbody { margin-top: 8px; font-size: 13px; line-height: 1.6; color: #3f3f46; }
  .relbody :global(p), .relbody :global(ul), .relbody :global(ol) { margin: 4px 0; }
  .relbody :global(ul), .relbody :global(ol) { padding-left: 20px; }
  .relbody :global(h1), .relbody :global(h2), .relbody :global(h3) { font-size: 13px; font-weight: 600; margin: 8px 0 2px; }
  .relbody :global(a) { color: var(--ink); }
  .relbody :global(code) { font-family: var(--mono); font-size: 12px; background: #efefe9; padding: 1px 4px; border-radius: 2px; }
  .relbody :global(pre) { background: var(--paper); border: 1px solid var(--rule); padding: 10px 12px; overflow-x: auto; font-size: 12px; }
</style>

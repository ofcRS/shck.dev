---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { TOOLS } from '../site.config';

const all = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const postCount = all.length;
const posts = all.slice(0, 5);

const version = (title: string) => {
  const m = title.match(/v?(\d+\.\d+\.\d+)/);
  return m ? `v${m[1]}` : '—';
};

const iso = (d: string | Date | null | undefined) =>
  d ? new Date(d).toISOString().slice(0, 10) : '';

// Per-tool latest release — one release collection per tool (see content.config.ts),
// fetched from github.com/<repo>/releases.atom at build time; normalized exactly like
// changelog.astro. try/catch so a missing/failed feed yields an empty array.
const tools = await Promise.all(
  TOOLS.map(async (t) => {
    let entries: any[] = [];
    try {
      entries = (await getCollection(`releases_${t.name}` as any)) as any[];
    } catch {
      entries = [];
    }
    const releases = entries
      .map((e) => {
        const d: any = e.data;
        return {
          title: d.title ?? e.id,
          url: d.url ?? `https://github.com/${t.repo}/releases`,
          // feed-loader v2 schema: releases.atom date lives in `updated` (published is
          // null for GitHub releases).
          date: d.updated ?? d.published ?? null,
        };
      })
      .sort((a, b) => new Date(b.date ?? 0).valueOf() - new Date(a.date ?? 0).valueOf());
    return { tool: t, latest: releases[0] ?? null };
  }),
);

const latest = tools
  .filter((t) => t.latest)
  .sort((a, b) => new Date(b.latest!.date ?? 0).valueOf() - new Date(a.latest!.date ?? 0).valueOf())
  .map((t) => ({ label: `${t.tool.name} ${version(t.latest!.title)}` }))[0];
---

<Base>
  <section class="hero rise">
    <h1>I build developer tools</h1>
    {latest && <div class="stamp">latest: {latest.label}</div>}
    <p class="intro">
      I'm Aleksandr. I build small developer tools — right now <b>ccx</b> (context for Claude
      Code) and <b>notion-mcp</b> (Notion over MCP).
    </p>
  </section>

  <section class="rise">
    <h2>tools</h2>
    <div class="cells">
      {
        tools.map(({ tool: t, latest: rel }) => (
          <div class="cell">
            <div class="name">
              <a href={`https://github.com/${t.repo}`}>{t.name}</a>
            </div>
            <p class="blurb">{t.blurb}</p>
            <div class="cmeta">
              <span class="ver">{rel ? version(rel.title) : 'wip'}</span>
              <span>{t.repo}</span>
              {rel?.date && <span>{iso(rel.date)}</span>}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="rise">
    <h2>writing</h2>
    {
      posts.length ? (
        <div class="rows">
          {posts.map((p) => (
            <div class="row">
              <span class="date">{iso(p.data.date)}</span>
              <a class="title" href={`/posts/${p.id}/`}>
                {p.data.title}
              </a>
            </div>
          ))}
          {postCount > 5 && (
            <div class="row">
              <span class="date" />
              <a class="endlink" href="/posts/">
                all posts →
              </a>
            </div>
          )}
        </div>
      ) : (
        <p class="note">(no posts yet)</p>
      )
    }
  </section>
</Base>

<style>
  .hero h1 { font-size: 50px; letter-spacing: -1.6px; line-height: 1.02; max-width: 13ch; margin: 36px 0 18px; }
  .hero .stamp { margin: 0 0 22px; }
  .hero .intro { margin-bottom: 4px; }
  @media (max-width: 620px) {
    .hero h1 { font-size: 34px; letter-spacing: -1px; }
  }
</style>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const iso = (d: string | Date | null | undefined) =>
  d ? new Date(d).toISOString().slice(0, 10) : '';
---

<Base title="posts" description="All posts on shck.dev">
  <section class="rise">
    <h1>writing</h1>
    {
      posts.length ? (
        <div class="rows">
          {posts.map((p) => (
            <div class="row">
              <span class="date">{iso(p.data.date)}</span>
              <a class="title" href={`/posts/${p.id}/`}>
                {p.data.title}
              </a>
            </div>
          ))}
        </div>
      ) : (
        <p class="note">(no posts yet)</p>
      )
    }
  </section>
</Base>
